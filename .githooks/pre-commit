#!/usr/bin/env bash
set -euo pipefail

# ── Formatting check ──────────────────────────────────────────────────────────
unformatted=$(gofmt -l .)
if [ -n "$unformatted" ]; then
  echo "pre-commit: the following files need formatting (run gofmt -w .):"
  echo "$unformatted"
  exit 1
fi

# ── Vet ───────────────────────────────────────────────────────────────────────
go vet ./...

# ── Lint ──────────────────────────────────────────────────────────────────────
if command -v golangci-lint &>/dev/null; then
  golangci-lint run ./...
else
  echo "pre-commit: golangci-lint not found — skipping lint (run: go install github.com/golangci/golangci-lint/v2/cmd/golangci-lint@latest)"
fi

# ── Secret scan ───────────────────────────────────────────────────────────────
# Scan staged diff for common secret patterns.
staged_diff=$(git diff --cached)

secrets_found=0
while IFS= read -r line; do
  if echo "$line" | grep -qE '^\+' && ! echo "$line" | grep -qE '^\+\+\+'; then
    if echo "$line" | grep -qE "(BEGIN (RSA |EC |DSA |OPENSSH )?PRIVATE KEY|AKIA[0-9A-Z]{16}|password[[:space:]]*=[[:space:]]*[\"'][^\"']{8,}[\"'])"; then
      echo "pre-commit: possible secret detected in staged changes:"
      echo "  $line"
      secrets_found=1
    fi
  fi
done <<< "$staged_diff"

if [ "$secrets_found" -eq 1 ]; then
  echo "pre-commit: commit blocked — review the lines above and remove secrets before committing."
  exit 1
fi
