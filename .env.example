# Cuttlegate — environment variables for docker-compose
# Copy to .env and adjust as needed: cp .env.example .env

# PostgreSQL
DATABASE_URL=postgres://cuttlegate:cuttlegate@db:5432/cuttlegate?sslmode=disable

# OIDC — uses localhost (server reaches Dex via extra_hosts: host-gateway)
OIDC_ISSUER=http://localhost:5556/dex
OIDC_CLIENT_ID=cuttlegate
OIDC_REDIRECT_URI=http://localhost:8080/callback

# Server
ADDR=:8080

# Optional — use when server and browser need different OIDC URLs
# OIDC_SPA_AUTHORITY=http://localhost:5556/dex
# OIDC_AUDIENCE=
# OIDC_ROLE_CLAIM=role
# AUTO_MIGRATE=false
# EVAL_RATE_LIMIT=600
# EVAL_RATE_LIMIT_WINDOW=1m
